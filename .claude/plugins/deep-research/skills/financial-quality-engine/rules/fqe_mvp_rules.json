{
  "version": "0.1.0",
  "notes": "FQE MVP ruleset. Thresholds are heuristics for Phase 1; move to calibrated per-industry thresholds later.",
  "rules": {
    "fq_cash_003": {
      "name": "经营现金流支撑不足",
      "severity": {
        "high": { "ocf_to_ni_lt": 0.5 },
        "medium": { "ocf_to_ni_lt": 0.8 }
      }
    },
    "fq_cash_005": {
      "name": "自由现金流覆盖不足",
      "severity": {
        "high": { "fcf_to_ni_lt": 0.3 },
        "medium": { "fcf_to_ni_lt": 0.6 }
      }
    },
    "fq_rev_001": {
      "name": "应收增速显著快于收入增速",
      "params": {
        "delta_yoy_gt": {
          "medium": 0.20,
          "high": 0.35
        }
      }
    },
    "fq_bs_002": {
      "name": "存货增长显著快于收入增长",
      "params": {
        "delta_yoy_gt": {
          "medium": 0.20,
          "high": 0.35
        }
      }
    },
    "fq_bs_004": {
      "name": "商誉占净资产比例偏高",
      "params": {
        "goodwill_to_equity_gt": {
          "medium": 0.30,
          "high": 0.50
        }
      }
    },
    "fq_debt_001": {
      "name": "短债对现金压力偏高",
      "params": {
        "st_debt_to_cash_gt": {
          "medium": 0.80,
          "high": 1.20
        }
      }
    },
    "fq_leverage_002": {
      "name": "净负债占净资产比例偏高",
      "params": {
        "net_debt_to_equity_gt": {
          "medium": 0.60,
          "high": 1.00
        }
      }
    },
    "fq_gov_001": { "name": "审计意见非标准" },
    "fq_gov_002": { "name": "近 5 年存在财务重述" },
    "fq_gov_003": { "name": "近 3 年存在监管问询/关注函" }
  }
}

